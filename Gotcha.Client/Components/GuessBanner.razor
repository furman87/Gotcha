<div class="swap-banner bg-yellow-900 border border-yellow-600 text-yellow-200 rounded-lg p-3 mb-4 flex items-center gap-2">
    <span class="text-xl">⚠️</span>
    <span class="font-bold">
        The word has been changed!
        @if (ExtraGuesses > 0)
        {
            <span> You have @ExtraGuesses extra @(ExtraGuesses == 1 ? "guess" : "guesses").</span>
        }
        else
        {
            <span> No extra guesses were added.</span>
        }
    </span>
</div>

@code {
    [Parameter] public int ExtraGuesses { get; set; }
}
