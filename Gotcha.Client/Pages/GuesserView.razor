@page "/game/{GameId:guid}/guess"
@using Gotcha.Client.Components
@using Gotcha.Client.Models
@using Gotcha.Client.Services
@using System.Timers
@inject GameApiService Api
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Gotcha - Guesser</PageTitle>

<div class="w-full max-w-lg">
    <!-- Status bar -->
    <div class="flex justify-between items-center mb-4 text-sm text-gray-400">
        <span class="bg-[#1a1a1b] border border-[#3a3a3c] rounded px-2 py-1">
            🔍 Guesser View
        </span>
        <span class="flex items-center gap-1">
            <span class="w-2 h-2 rounded-full bg-green-500 inline-block @(IsPolling ? "animate-pulse" : "")"></span>
            Live
        </span>
    </div>

    @if (_game == null)
    {
        <p class="text-gray-400 text-center">Loading...</p>
    }
    else if (_game.Status == "waiting")
    {
        <p class="text-gray-400 text-center">Waiting for setter to choose a word...</p>
    }
    else
    {
        @if (_swapJustOccurred)
        {
            <GuessBanner ExtraGuesses="_game.BonusGuesses" />
        }

        <div class="flex justify-between items-center mb-3 text-sm">
            @{
                var totalGuesses = _game.GuessesAllowed;
                var usedGuesses = _game.Guesses.Count;
                var remaining = totalGuesses - usedGuesses;
            }
            <span class="text-gray-400">
                @usedGuesses / @totalGuesses guesses used
                @if (remaining > 0 && !_game.IsOver)
                {
                    <span class="text-gray-500"> (@remaining remaining)</span>
                }
            </span>
            @if (_game.IsOver)
            {
                @if (_game.Winner == "guesser")
                {
                    <span class="text-green-400 font-bold">🎉 You Win!</span>
                }
                else
                {
                    <span class="text-red-400 font-bold">😞 You Lost</span>
                }
            }
        </div>

        <TileGrid Guesses="_game.Guesses"
                  CurrentInput="@_currentInput"
                  TotalRows="@_game.GuessesAllowed"
                  SwapAfterGuess="@_game.SwapOccurredAfterGuess" />

        @if (!string.IsNullOrEmpty(_guessError))
        {
            <p class="text-red-400 text-sm text-center mb-2">⚠ @_guessError</p>
        }

        @if (_game.IsOver)
        {
            <div class="bg-[#1a1a1b] border border-[#3a3a3c] rounded-lg p-4 mt-4 text-center">
                <p class="text-gray-400 text-sm">The word was:</p>
                <p class="text-3xl font-bold tracking-widest font-mono text-white mt-1">@(_game.Answer?.ToUpperInvariant())</p>
            </div>
        }
        else
        {
            <Keyboard Guesses="_game.Guesses" OnKeyPress="HandleVirtualKey" />
        }
    }
</div>

@code {
    [Parameter] public Guid GameId { get; set; }

    private GameStateResponse? _game;
    private string _currentInput = "";
    private string? _guessError;
    private bool _submitting;
    private bool _swapJustOccurred;
    private bool IsPolling = true;
    private Timer? _timer;
    private int _lastKnownSwapState = -1;

    private DotNetObjectReference<GuesserView>? _dotNetRef;
    private bool _keyListenerPending;
    private bool _keyListenerRegistered;
    private bool _disposed;

    protected override async Task OnInitializedAsync()
    {
        await LoadGame();
        _timer = new Timer(2000);
        _timer.Elapsed += async (_, _) => await InvokeAsync(async () =>
        {
            await PollGame();
            StateHasChanged();
        });
        _timer.Start();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_keyListenerPending && !_keyListenerRegistered && _game?.Status == "active" && !_game.IsOver)
        {
            await ActivateKeyListener();
        }
        else if (_keyListenerRegistered && _game?.IsOver == true)
        {
            _keyListenerRegistered = false;
            try { await JS.InvokeVoidAsync("removeKeyListener"); } catch { }
        }
    }

    private async Task ActivateKeyListener()
    {
        if (_keyListenerPending || _keyListenerRegistered) return;
        _keyListenerPending = true;
        _dotNetRef ??= DotNetObjectReference.Create(this);
        await Task.Delay(100);
        if (!_disposed && _game?.Status == "active" && _game.IsOver != true)
        {
            try
            {
                await JS.InvokeVoidAsync("addKeyListener", _dotNetRef);
                _keyListenerRegistered = true;
            }
            catch { }
        }
        _keyListenerPending = false;
    }

    [JSInvokable]
    public async Task HandleKeyFromJs(string key)
    {
        if (_game?.Status != "active" || _game.IsOver) return;
        _guessError = null;
        if (key == "Enter")
        {
            await SubmitGuess();
        }
        else if (key == "Backspace")
        {
            if (_currentInput.Length > 0)
                _currentInput = _currentInput[..^1];
            StateHasChanged();
        }
        else if (key.Length == 1 && char.IsLetter(key[0]) && _currentInput.Length < 5)
        {
            _currentInput += key.ToLowerInvariant();
            StateHasChanged();
        }
    }

    private async Task LoadGame()
    {
        try
        {
            _game = await Api.GetGameAsync(GameId);
            if (_game?.SwapOccurredAfterGuess.HasValue == true)
                _lastKnownSwapState = _game.SwapOccurredAfterGuess.Value;
        }
        catch { }
    }

    private async Task PollGame()
    {
        try
        {
            var newState = await Api.GetGameAsync(GameId);
            if (newState == null) return;

            bool swapNowDetected = newState.SwapOccurredAfterGuess.HasValue
                && newState.SwapOccurredAfterGuess.Value != _lastKnownSwapState;

            if (swapNowDetected)
            {
                _swapJustOccurred = true;
                _lastKnownSwapState = newState.SwapOccurredAfterGuess ?? -1;
            }

            _game = newState;
        }
        catch { }
    }

    private void HandleVirtualKey(string key)
    {
        ProcessKey(key);
    }

    private void ProcessKey(string key)
    {
        _guessError = null;
        if (key == "Enter" || key == "ENTER")
        {
            _ = SubmitGuess();
        }
        else if (key == "Backspace" || key == "⌫")
        {
            if (_currentInput.Length > 0)
                _currentInput = _currentInput[..^1];
        }
        else if (key.Length == 1 && char.IsLetter(key[0]) && _currentInput.Length < 5)
        {
            _currentInput += key.ToLowerInvariant();
        }
    }

    private async Task SubmitGuess()
    {
        if (_submitting || _currentInput.Length != 5) return;
        _submitting = true;
        _guessError = null;

        try
        {
            var (state, error) = await Api.SubmitGuessAsync(GameId, _currentInput);
            if (error != null)
            {
                _guessError = error;
            }
            else
            {
                _swapJustOccurred = false;
                _currentInput = "";
                _game = state;
            }
        }
        catch (Exception ex)
        {
            _guessError = $"Error submitting guess: {ex.Message}";
        }
        finally
        {
            _submitting = false;
        }
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        _timer?.Dispose();
        IsPolling = false;
        if (_keyListenerRegistered)
        {
            _keyListenerRegistered = false;
            try { await JS.InvokeVoidAsync("removeKeyListener"); } catch { }
        }
        _dotNetRef?.Dispose();
    }
}
